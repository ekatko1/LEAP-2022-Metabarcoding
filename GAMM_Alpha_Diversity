meta_clean <- meta %>%
  rename(
    Sample = sample_name,
    Movement = flow_rate,
    NutrientP = nutrient_addition,
    Node = upstream_downstream,
    Mesocosm = tank,
    Day = time
  ) %>%
  mutate(
    Sample = gsub("_R[0-9]+$", "", Sample),
    Node = factor(ifelse(Node == "Up", 1, 2)),
    Day_num = case_when(
      Day == "T1" ~ 0,
      Day == "T2" ~ 28,
      Day == "T3" ~ 49,
      Day == "T4" ~ 73,
      Day == "T5" ~ 91
    )
  ) %>%
  distinct(Sample, .keep_all = TRUE)

div <- hill_results %>%
  left_join(meta_clean, by = "Sample") %>%
  filter(SampleType == "sample") %>%
  filter(Mesocosm != "H7") %>%
  mutate(Mesocosm = factor(Mesocosm))

#==================================================
# 5) GAMM
#==================================================

model_list <- list()

for (hill in c("q0", "q1", "q2")) {
  
  k_day <- 5
  k <- 3
  
  formula_text <- glue(
    "{hill} ~
      Node +
      ti(Day_num, by = Node, k = {k_day}) +
      ti(Movement, by = Node, k = {k}) +
      ti(NutrientP, by = Node, k = {k}) +
      ti(Movement, Day_num, by = Node, k = c({k},{k_day})) +
      ti(NutrientP, Day_num, by = Node, k = c({k},{k_day})) +
      ti(Movement, NutrientP, by = Node, k = c({k},{k})) +
      ti(Movement, NutrientP, Day_num, by = Node, k = c({k},{k},{k_day})) +
      s(Mesocosm, bs = 're')"
  )
  
  model_list[[hill]] <- gam(as.formula(formula_text), data = div, method = "REML")
}

#==================================================
# 6) PREDICT SURFACE (MATCH THEIR LOGIC)
#==================================================

predict_surface_fixed <- function(fit, day_vals, data) {
  
  surface <- expand.grid(
    Movement = seq(0, 40, by = 1),
    NutrientP = seq(min(data$NutrientP), max(data$NutrientP), length = 100),
    Day_num = day_vals,
    Node = levels(data$Node)
  )
  
  # Fix factor structure
  surface$Node <- factor(surface$Node, levels = levels(data$Node))
  
  # Remove impossible downstream combos
  surface <- surface %>%
    filter(!(Node == "2" & Movement < 10))
  
  # Add required random effect variable
  surface$Mesocosm <- levels(data$Mesocosm)[1]
  surface$Mesocosm <- factor(surface$Mesocosm, levels = levels(data$Mesocosm))
  
  # Predict
  surface$pred <- predict(
    fit,
    newdata = surface,
    type = "response",
    exclude = "s(Mesocosm)"
  )
  
  # Label nicely
  surface$PondPosition <- c("Upstream", "Downstream")[as.numeric(surface$Node)]
  
  return(surface)
}

#==================================================
# 7) PLOT FUNCTION
#==================================================

plot_surface_fixed <- function(surface, hill) {
  
  ggplot(surface, aes(x = NutrientP, y = Movement, z = pred)) +
    geom_contour_filled() +
    geom_contour(color = "black") +
    facet_grid(rows = vars(PondPosition), cols = vars(Day_num)) +
    labs(
      fill = paste("Hill", hill),
      x = "Nutrients",
      y = "Connectivity"
    ) +
    theme_bw()
}

