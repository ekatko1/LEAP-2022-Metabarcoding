#==================================================
# 2) PROCESS + AVERAGE REPLICATES
#==================================================

process_genus_data_with_reps <- function(taxa_df) {
  
  taxa_df <- as.data.table(taxa_df)
  
  tax_cols <- c("domain","supergroup","division","subdivision",
                "class","order","family","genus","species", 
                "kingdom", "phylum", "marker")
  
  sample_cols <- setdiff(colnames(taxa_df), tax_cols)
  taxa_df <- taxa_df[, c("genus", sample_cols), with = FALSE]
  
  taxa_df <- taxa_df[genus != "Unknown" & !is.na(genus)]
  taxa_df <- taxa_df[, lapply(.SD, sum), by = genus]
  
  taxa_mat <- as.matrix(taxa_df[, -1])
  rownames(taxa_mat) <- taxa_df$genus
  
  taxa_rel <- sweep(taxa_mat, 2, colSums(taxa_mat), FUN = "/")
  
  sample_names <- colnames(taxa_rel)
  base_names <- gsub("_R[0-9]+$", "", sample_names)
  
  taxa_rel_avg <- sapply(unique(base_names), function(bn) {
    cols <- which(base_names == bn)
    rowMeans(taxa_rel[, cols, drop = FALSE])
  })
  
  taxa_rel_avg * 100
}

taxa_rel <- process_genus_data_with_reps(taxa)

#==================================================
# 3) HILL NUMBERS
#==================================================

calculate_hill_numbers <- function(rel_matrix) {
  
  prop_matrix <- rel_matrix / 100
  
  data.frame(
    Sample = colnames(prop_matrix),
    q0 = colSums(prop_matrix > 0),
    q1 = exp(apply(prop_matrix, 2, function(x) diversity(x, "shannon"))),
    q2 = apply(prop_matrix, 2, function(x) diversity(x, "invsimpson"))
  )
}

hill_results <- calculate_hill_numbers(taxa_rel)

